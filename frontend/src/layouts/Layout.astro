---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Stock Radar</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen">
    <nav class="border-b border-slate-700 px-6 py-4">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a href="/" class="text-xl font-bold flex items-center gap-2">
          <span class="text-blue-500">Stock</span>
          <span>Radar</span>
        </a>
        <div class="flex gap-6 text-sm">
          <a href="/" class="text-slate-400 hover:text-white transition">首页</a>
          <a href="/market" class="text-slate-400 hover:text-white transition">涨跌停池</a>
        </div>
      </div>
    </nav>
    <main class="max-w-7xl mx-auto px-6 py-6">
      <slot />
    </main>
    <footer class="border-t border-slate-700 px-6 py-4 mt-12">
      <div class="max-w-7xl mx-auto text-center text-sm text-slate-500">
        Stock Radar v2.0 - 扫描市场，捕捉机会
      </div>
    </footer>
  </body>
</html>
